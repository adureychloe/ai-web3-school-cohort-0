# Agent Commerce Sandbox - Testnet Configuration
# Copy this to .env and fill in your values
# Default (no .env) = simulation mode, no real funds at risk

# Base Sepolia RPC
# Public: https://sepolia.base.org
# Or from Alchemy/Infura/etc
RPC_URL=https://sepolia.base.org

# Testnet private key (hex without 0x prefix)
# Get test ETH from Base Sepolia faucet
# NEVER use a mainnet key
TEST_PRIVATE_KEY=

# Chain ID
CHAIN_ID=84532

# Contract address (after Step 3 deployment)
RECEIPT_REGISTRY_ADDRESS=
